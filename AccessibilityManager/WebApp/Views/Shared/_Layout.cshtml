<!DOCTYPE html>
<html lang="hr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

</head>

<body>
    <header class="site-header">

        <nav class="main-nav">
            <div class="nav-container">
                <a class="nav-logo">Accessible World</a>
                <ul class="nav-links">
                    <li><a asp-controller="Home" asp-action="Index">Activities</a></li>

                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <li><a asp-controller="Profile" asp-action="Profile">Profile</a></li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li><a asp-controller="Admin" asp-action="Admin">Dashboard</a></li>
                        }

                        <li><a asp-controller="Account" asp-action="Logout">Logout</a></li>
                    }
                    else
                    {
                        <li><a asp-controller="Account" asp-action="Login" class="nav-btn">Login</a></li>                            
                    }

                </ul>      
            </div>
        </nav>

    </header>

    <div class="site-content">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="nav-container">
            &copy; 2026 - Accessible World
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>