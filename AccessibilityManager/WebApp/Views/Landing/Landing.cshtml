<!DOCTYPE html>
<html lang="hr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Welcome</title>

    <link rel="stylesheet" href="~/css/landing.css"/>

</head>
<body>
    <div class="main-content">

        <section class="landing-container">

            <div class="landing-content">

                <h1>Accessible World</h1>
                <p>Find the best activities, restaurants and accommodations that are accessible to people with disabilities.</p>
                
                <div class="btn-primary">
                    <a asp-controller="Home" asp-action="Index" class="btn-activities">Search activities</a>
                    <a asp-controller="Account" asp-action="Register" class="btn-activities">Join us</a>                
                </div>

            </div>

        </section>

        <section class="features-content">

            <div class="feature-card">
                <div class="icon">📍</div>
                <h3>Various Types</h3>
                <p>Everything in one place divided by categories.</p>
            </div>

            <div class="feature-card">
                <div class="icon">♿</div>
                <h3>Verified Accessibility</h3>
                <p>Transportation information and specialized guides.</p>
            </div>

            <div class="feature-card">
                <div class="icon">⭐</div>
                <h3>Reviews</h3>
                <p>Read the experiences of others and leave your rating.</p>
            </div>

        </section>
    </div>
</body>